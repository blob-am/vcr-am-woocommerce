<?xml version="1.0"?>
<ruleset name="vcr-am-fiscal-receipts">
    <description>
        Project PHPCS / Plugin Check ruleset for the VCR — Fiscal Receipts
        for Armenia plugin. Picks up the WordPress + WordPress-Extra
        rulesets, then suppresses sniffs that produce false positives
        for our codebase shape.
    </description>

    <!--
        Apply to plugin source only — exclude vendor, tests, build
        artefacts. The build script's .distignore already keeps these
        out of the WP.org ZIP, but PCP runs against the staged tree so
        we belt-and-braces here too.
    -->
    <file>.</file>
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>vendor-prefixed/*</exclude-pattern>
    <exclude-pattern>vendor-bin/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>tests/*</exclude-pattern>
    <exclude-pattern>build/*</exclude-pattern>
    <exclude-pattern>dist/*</exclude-pattern>
    <exclude-pattern>playground/*</exclude-pattern>

    <rule ref="WordPress"/>
    <rule ref="WordPress-Extra"/>

    <!--
        Sniff suppressions with rationale.

        WordPress.Security.EscapeOutput.ExceptionNotEscaped:
            PCP treats every dynamic value inside `throw new
            FooException(sprintf(...))` as user-facing output and
            demands esc_html() on each interpolated arg. In practice
            exception messages are caught and either logged (where the
            logger handles its own escaping) or rendered via wp_die()
            (which escapes itself), so the per-arg escape is purely
            ritual noise. Industry consensus is to suppress this sniff
            project-wide for plugins that use modern typed exceptions.
    -->
    <rule ref="WordPress.Security.EscapeOutput.ExceptionNotEscaped">
        <severity>0</severity>
    </rule>

    <!--
        WordPress.WP.AlternativeFunctions.parse_url_parse_url:
            We use wp_parse_url() in src/. This rule sometimes
            mis-detects through namespacing — keep it on at warning
            level for visibility, not error level.

            (Already converted in source; the suppression above for
            ExceptionNotEscaped is the only one we need to fully
            silence.)
    -->
</ruleset>
