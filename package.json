{
    "name": "vcr-am-woocommerce-e2e",
    "version": "0.1.0",
    "private": true,
    "description": "E2E test harness for the VCR fiscal-receipt WooCommerce plugin. Not published — only consumed by the CI workflow and local `npm run test:e2e`.",
    "license": "GPL-2.0-or-later",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "env:start": "wp-env start",
        "env:stop": "wp-env stop",
        "env:destroy": "wp-env destroy",
        "env:logs": "wp-env logs",
        "mock:start": "node tests/E2E/mock-vcr-server.mjs",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:install": "playwright install --with-deps chromium"
    },
    "devDependencies": {
        "@playwright/test": "^1.50.0",
        "@wordpress/env": "^10.0.0"
    }
}
