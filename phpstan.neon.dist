parameters:
    level: max
    paths:
        - src
    excludePaths:
        analyseAndScan:
            - vendor
            - vendor-prefixed (?)
            - vendor-bin
            - tests
    treatPhpDocTypesAsCertain: false
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
        - vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
        # Action Scheduler functions (`as_enqueue_async_action`,
        # `as_schedule_single_action`, etc.) are bundled with WooCommerce
        # but live in this separate stub file. We use them in FiscalQueue.
        - vendor/php-stubs/woocommerce-stubs/woocommerce-packages-stubs.php
        # WP-CLI class + helper stubs for src/Cli/ — without these PHPStan
        # would flag every WP_CLI::add_command / WP_CLI::error call as
        # class.notFound (CLI-only context, no runtime requirement).
        - vendor/php-stubs/wp-cli-stubs/wp-cli-stubs.php
        # Strauss generates an independent composer-autoloader for the
        # prefixed deps (SDK, Guzzle, php-http/*). PHPStan's discovery hits
        # only the main vendor/autoload.php by default, so without this
        # bootstrap it can't see classes like
        # `BlobSolutions\WooCommerceVcrAm\Vendor\BlobSolutions\VcrAm\VcrClient`
        # and reports them as `class.notFound`. `bootstrapFiles` does not
        # support the `(?)` optional-path marker; running `composer phpstan`
        # without `vendor-prefixed/` present fails fast — which is the right
        # signal that `composer install` was skipped or `composer strauss`
        # didn't run.
        - vendor-prefixed/autoload.php
includes:
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
