parameters:
    level: max
    paths:
        - src
    excludePaths:
        analyseAndScan:
            - vendor
            - vendor-prefixed (?)
            - vendor-bin
            - tests
    treatPhpDocTypesAsCertain: false
    bootstrapFiles:
        - vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
includes:
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
